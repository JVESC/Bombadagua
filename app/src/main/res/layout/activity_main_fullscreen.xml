<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Bloco azul superior -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#B8D9F5"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_gota"
                    android:background="@drawable/bg_icon_white"
                    android:padding="8dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvNomeApp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fluvi"
                        android:textSize="18sp"
                        android:textColor="#000000"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monitoramento de vazão"
                        android:textSize="13sp"
                        android:textColor="#555555"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Consumo hoje"
                android:layout_marginTop="16dp"
                android:textColor="#555555"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:id="@+id/tvConsumoHoje"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="86"
                    android:textSize="40sp"
                    android:textColor="#000000"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" litros"
                    android:textSize="16sp"
                    android:textColor="#000000"
                    android:layout_marginBottom="8dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvComparativo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="18% menos que ontem"
                android:textColor="#2E7D32"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Bloco branco: vazão atual / água poupada -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vazão atual"
                    android:textColor="#555555"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvVazaoAtual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.2 L/min"
                    android:textSize="20sp"
                    android:textColor="#000000"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Água poupada"
                    android:textColor="#555555"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvAguaPoupada"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="312 L"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Lista de pontos monitorados: preenche o resto da tela -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pontos monitorados"
                android:textStyle="bold"
                android:textColor="#000000"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <!-- Item: Chuveiro -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="🚿  Chuveiro"
                    android:textColor="#000000"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvVazaoChuveiro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.1 L/min"
                    android:textColor="#000000"
                    android:textSize="16sp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"/>

            <!-- Item: Cozinha -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="🍷  Cozinha"
                    android:textColor="#000000"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvVazaoCozinha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.8 L/min"
                    android:textColor="#000000"
                    android:textSize="16sp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"/>

            <!-- Item de alerta: Torneira jardim -->
            <LinearLayout
                android:id="@+id/layoutAlertaVazamento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="⚠️  Torneira jardim"
                    android:textColor="#C62828"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="vazamento"
                    android:textColor="#C62828"
                    android:textSize="16sp"/>
            </LinearLayout>

            <!-- Espaço flexível empurra o botão pro rodapé -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- Botão: Ver alerta de vazamento -->
            <Button
                android:id="@+id/btnVerAlerta"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Ver alerta de vazamento  →"
                android:background="@drawable/bg_botao_preto"
                app:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:layout_marginBottom="16dp"/>

            <!-- Botão: Ver histórico -->
            <Button
                android:id="@+id/btnVerHistorico"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Ver histórico  →"
                android:background="@drawable/bg_botao_borda"
                app:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textColor="#000000"
                android:textAllCaps="false"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>