<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".VazamentoActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Botão voltar -->
            <LinearLayout
                android:id="@+id/btnVoltar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_seta_voltar"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voltar"
                    android:textSize="16sp"
                    android:textColor="#000000"/>
            </LinearLayout>

            <!-- Ícone + título -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="⚠️"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@drawable/bg_card_vermelho"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vazamento detectado"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:textColor="#000000"/>

                    <TextView
                        android:id="@+id/tvNomePonto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Torneira do jardim"
                        android:textSize="14sp"
                        android:textColor="#666666"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Card vermelho: vazão contínua -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_vermelho"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vazão contínua há"
                    android:textColor="#C62828"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvDuracaoVazamento"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3h 40min"
                    android:textColor="#C62828"
                    android:textSize="30sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sem uso normal registrado nesse período"
                    android:textColor="#C62828"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Água perdida / Vazão atual -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_cinza"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Água perdida"
                        android:textColor="#555555"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvAguaPerdida"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="64 L"
                        android:textSize="20sp"
                        android:textColor="#000000"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_cinza"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vazão atual"
                        android:textColor="#555555"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvVazaoAtualDetalhe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.3 L/min"
                        android:textSize="20sp"
                        android:textColor="#000000"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Linha do tempo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Linha do tempo"
                android:textStyle="bold"
                android:textColor="#000000"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <!-- Item 1: uso normal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="#999999"
                    android:textSize="14sp"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14:20 — uso normal registrado"
                        android:textColor="#000000"
                        android:textSize="14sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.9 L/min por 4 min"
                        android:textColor="#888888"
                        android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Item 2: vazão contínua -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="#C62828"
                    android:textSize="14sp"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14:24 — vazão contínua começou"
                        android:textColor="#C62828"
                        android:textSize="14sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.3 L/min, sem variação"
                        android:textColor="#C62828"
                        android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Botões -->
            <Button
                android:id="@+id/btnVerComoConsertar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Ver como consertar"
                android:background="@drawable/bg_botao_preto"
                app:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnMarcarResolvido"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Marcar como resolvido"
                android:background="@drawable/bg_botao_borda"
                app:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textColor="#000000"
                android:textAllCaps="false"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
